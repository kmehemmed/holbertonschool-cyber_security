#!/usr/bin/env bash
# Init script to manage manage_my_process

ACTION=$1
PID_FILE="/tmp/my_process.pid"
COMMAND="./manage_my_process"

case "$ACTION" in
    start)
        # Start the process in the background (&) and save its PID ($!)
        $COMMAND &
        echo $! > "$PID_FILE"
        echo "manage_my_process started"
        ;;
    stop)
        # Kill the process using the stored PID and remove the file
        kill "$(cat "$PID_FILE")"
        rm -f "$PID_FILE"
        echo "manage_my_process stopped"
        ;;
    restart)
        # Stop first
        kill "$(cat "$PID_FILE")"
        rm -f "$PID_FILE"
        # Then start
        $COMMAND &
        echo $! > "$PID_FILE"
        echo "manage_my_process restarted"
        ;;
    *)
        # Default usage message
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
